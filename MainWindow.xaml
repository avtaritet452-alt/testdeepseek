<Window x:Class="LSDLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LSD Launcher" 
        Height="650" 
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a1a"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize">

    <Border Background="#1a1a1a" CornerRadius="10" BorderBrush="#A60B00" BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" Background="#2d2d2d" CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="LSD LAUNCHER" FontSize="16" FontWeight="Bold" 
                               Foreground="#A60B00" HorizontalAlignment="Center" 
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,15,0">
                        <Button x:Name="CloseButton" Content="✕" 
                                Background="Transparent" Foreground="White"
                                BorderThickness="0" FontSize="14" Cursor="Arrow"
                                Width="25" Height="25"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Левый список клиентов -->
                <Border Grid.Column="0" Background="#2d2d2d" CornerRadius="8" Margin="0,0,10,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBox x:Name="SearchBox" Grid.Row="0"
                                 Background="#1a1a1a" Foreground="#e0e0e0" 
                                 BorderBrush="#A60B00" BorderThickness="1" 
                                 Padding="8" Margin="10,10,10,5"
                                 TextChanged="SearchBox_TextChanged"/>

                        <Button x:Name="CheckLinksButton" Grid.Row="1"
                                Content="🔍 Проверить доступность клиентов"
                                Background="#A60B00" Foreground="White"
                                BorderThickness="0" Padding="8" Margin="10,5"
                                Cursor="Hand" Click="CheckLinksButton_Click"/>

                        <ListBox x:Name="ClientsList" Grid.Row="2"
                                 Background="#2d2d2d" BorderThickness="0"
                                 SelectionChanged="ClientsList_SelectionChanged"
                                 Margin="0,0,0,10">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#404040" BorderThickness="0,0,0,1" 
                                            Background="Transparent" Padding="12,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBlock Grid.Column="0" Text="{Binding StatusIcon}" 
                                                       Foreground="{Binding StatusColor}" FontSize="14" 
                                                       ToolTip="{Binding StatusTooltip}"/>
                                            
                                            <!-- Название с возможностью редактирования -->
                                            <TextBox x:Name="EditNameBox" Grid.Column="1"
                                                     Text="{Binding Name}" 
                                                     Foreground="#e0e0e0" Background="#1a1a1a"
                                                     BorderBrush="#A60B00" BorderThickness="1"
                                                     Padding="5,2" Margin="10,0,0,0"
                                                     Visibility="Collapsed"
                                                     LostFocus="EditNameBox_LostFocus"
                                                     KeyDown="EditNameBox_KeyDown"/>
                                            
                                            <TextBlock x:Name="NameBlock" Grid.Column="1"
                                                       Text="{Binding Name}" 
                                                       Foreground="#e0e0e0" FontSize="13" FontWeight="Bold" 
                                                       Margin="10,0,0,0" VerticalAlignment="Center"/>
                                            
                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                <Button Content="✏️" Background="Transparent" 
                                                        Foreground="#A60B00" BorderThickness="0"
                                                        Cursor="Hand" Width="25"
                                                        ToolTip="Переименовать"
                                                        Click="StartRename_Click"/>
                                                <Button Content="❌" Background="Transparent" 
                                                        Foreground="#A60B00" BorderThickness="0"
                                                        Cursor="Hand" Width="25"
                                                        ToolTip="Удалить"
                                                        Click="DeleteClient_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#A60B00"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Правая панель -->
                <Border Grid.Column="1" Background="#2d2d2d" CornerRadius="8" Padding="15">
                    <StackPanel>
                        <TextBlock Text="НИКНЕЙМ" Foreground="#a0a0a0" FontSize="10"/>
                        <TextBox x:Name="NicknameBox" Text="Player" 
                                 Background="#1a1a1a" Foreground="#e0e0e0" 
                                 BorderBrush="#A60B00" BorderThickness="1" 
                                 Padding="6" Margin="0,3,0,10"/>
                        
                        <Button x:Name="RandomNickButton" Content="🎲 Случайный ник се" 
                                Background="#A60B00" Foreground="White" 
                                Padding="8" Cursor="Hand" Margin="0,0,0,15"
                                Click="RandomNickButton_Click"/>

                        <CheckBox x:Name="RandomNickCheckBox" Content="Случайный ник при каждом запуске" Foreground="#e0e0e0" Margin="0,5"/>
                        <CheckBox x:Name="KeepFilesCheckBox" Content="Не удалять скачанные клиенты" Foreground="#e0e0e0" Margin="0,5"/>

                        <Border Background="#1a1a1a" CornerRadius="6" Padding="10" Margin="0,15,0,0">
                            <StackPanel>
                                <TextBlock Text="ВЫБРАННЫЙ КЛИЕНТ" FontSize="11" FontWeight="Bold" Foreground="#A60B00" Margin="0,0,0,10"/>
                                <TextBlock x:Name="ClientNameText" FontSize="13" FontWeight="Bold" Foreground="#e0e0e0" TextWrapping="Wrap"/>
                                <TextBlock x:Name="ClientTagsText" Foreground="#A60B00" FontSize="10" Margin="0,5,0,0"/>
                                <Button x:Name="LaunchButton" Content="LAUNCH" Background="#A60B00" Foreground="White" FontSize="13" FontWeight="Bold" Height="35" Margin="0,15,0,0" Click="LaunchButton_Click" IsEnabled="False" Cursor="Hand"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#1a1a1a" CornerRadius="6" Padding="10" Margin="0,15,0,0">
                            <StackPanel>
                                <TextBlock Text="ДОБАВИТЬ ЛОКАЛЬНЫЙ КЛИЕНТ" FontSize="11" FontWeight="Bold" Foreground="#A60B00" Margin="0,0,0,10"/>
                                <TextBox x:Name="LocalClientName" Background="#2d2d2d" Foreground="#e0e0e0" BorderBrush="#A60B00" BorderThickness="1" Padding="6" Margin="0,0,0,5" Text="Название клиента"/>
                                <TextBox x:Name="LocalClientTags" Background="#2d2d2d" Foreground="#e0e0e0" BorderBrush="#A60B00" BorderThickness="1" Padding="6" Margin="0,0,0,5" Text="#тег1 #тег2"/>
                                <Button x:Name="SelectZipButton" Content="📁 Выбрать ZIP-файл" Background="#3a3a3a" Foreground="White" Padding="8" Cursor="Hand" Margin="0,0,0,5" Click="SelectZipButton_Click"/>
                                <TextBlock x:Name="SelectedZipPath" Foreground="#A60B00" FontSize="10" Text="Файл не выбран"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <Border x:Name="ProgressBorder" Grid.Row="2" Background="#1a1a1a" CornerRadius="6" Height="40" Margin="10,5,10,5" Padding="10" Visibility="Collapsed">
                <Grid>
                    <ProgressBar x:Name="DownloadProgress" Minimum="0" Maximum="100" Foreground="#A60B00" Background="#2d2d2d" Height="12"/>
                    <Button x:Name="CancelDownloadButton" Content="Отмена" Background="#5C0000" Foreground="White" BorderThickness="0" Padding="8,4" Cursor="Hand" HorizontalAlignment="Right" Click="CancelDownloadButton_Click"/>
                </Grid>
            </Border>

            <Border Grid.Row="3" Background="#1a1a1a" Padding="8,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="VersionText" Foreground="#a0a0a0" FontSize="10" HorizontalAlignment="Left"/>
                    <TextBlock Grid.Column="1" x:Name="StatusText" Text="Готов" Foreground="#a0a0a0" FontSize="10" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="📢 @LSDLauncher" Foreground="#A60B00" FontSize="10" HorizontalAlignment="Right" Cursor="Hand" MouseLeftButtonDown="TelegramLink_MouseLeftButtonDown"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>